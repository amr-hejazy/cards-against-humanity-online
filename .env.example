# Backend (apps/backend/.env)
# Copy this file to apps/backend/.env and fill in real values.
# Required: DATABASE_URL, JWT_SECRET

# PostgreSQL connection string (e.g. Neon, Render, local)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname?sslmode=require

# Secret used to sign auth (JWT) tokens
JWT_SECRET=replace-with-a-long-random-string

# Token lifetime (optional, default: 1d)
JWT_EXPIRES_IN=1d

# Port the server listens on (optional, default: 3000)
PORT=3000

# Node environment (optional, default: development)
NODE_ENV=development

# Comma-separated list of allowed frontend origins (optional)
CORS_ORIGIN=http://localhost:5173

# Winston log directory (optional, default: logs)
LOGS_PATH=logs

# Upstash Redis (optional; app runs without it, just skips cache/rate-limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Frontend (apps/frontend/.env)
# Copy this file to apps/frontend/.env and adjust if needed.

# URL of the backend API / socket server (optional, default: http://localhost:3000)
VITE_SERVER_URL=http://localhost:3000
